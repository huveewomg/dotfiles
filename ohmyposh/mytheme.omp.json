{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "palette": {
    "primary": "#33CCCC",
    "accent": "#FF6699",
    "bg": "#1A1A1A",
    "fg": "#E0DEF4"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b0",
          "foreground": "p:bg",
          "background": "p:primary",
          "template": " \uf07b {{ .Path }} ",
          "properties": { "style": "folder" }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "p:bg",
          "background": "p:accent",
          "template": " \ue0a0 {{ .HEAD }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }} ",
          "properties": { "fetch_status": true }
        },
        {
          "type": "spotify",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "p:fg",
          "background": "p:bg",
          "template": " \uf1bc {{ .Artist }} - {{ .Track }} "
        },
        {
          "type": "time",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "p:fg",
          "background": "p:bg",
          "template": " \uf017 {{ .CurrentDate | date \"15:04\" }} "
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:primary",
          "template": " >"
        }
      ]
    }
  ],
  "final_space": true
}
